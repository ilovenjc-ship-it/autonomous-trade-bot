2026-04-19 05:18:11,686 | INFO | sqlalchemy.engine.Engine | SELECT trades.id, trades.trade_type, trades.status, trades.amount, trades.price_at_trade, trades.usd_value, trades.fee, trades.pnl, trades.pnl_pct, trades.strategy, trades.signal_reason, trades.tx_hash, trades.netuid, trades.network, trades.created_at, trades.executed_at, trades.error_message 
FROM trades ORDER BY trades.created_at DESC
 LIMIT ? OFFSET ?
