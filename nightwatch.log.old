2026-04-17 20:47:32,289 | INFO | sqlalchemy.engine.Engine | BEGIN (implicit)
2026-04-17 20:47:32,289 | INFO | sqlalchemy.engine.Engine | 
            SELECT
                COUNT(*)                                     AS total_trades,
                SUM(pnl)                                     AS total_pnl,
                SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END)    AS wins,
                SUM(CASE WHEN pnl <= 0 THEN 1 ELSE 0 END)   AS losses,
                MAX(pnl)                                     AS best,
                MIN(pnl)                                     AS worst,
                COUNT(DISTINCT strategy)                     AS active_strategies
            FROM trades
            
        
2026-04-17 20:47:32,289 | INFO | sqlalchemy.engine.Engine | [cached since 1819s ago] ()
2026-04-17 20:47:32,292 | INFO | sqlalchemy.engine.Engine | BEGIN (implicit)
2026-04-17 20:47:32,293 | INFO | sqlalchemy.engine.Engine | 
            SELECT
                strategy,
                COUNT(*)                                        AS total_trades,
                SUM(pnl)                                        AS total_pnl,
                SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END)       AS wins,
                SUM(CASE WHEN pnl <= 0 THEN 1 ELSE 0 END)      AS losses,
                AVG(pnl)                                        AS avg_pnl,
                MAX(pnl)                                        AS best_trade,
                MIN(pnl)                                        AS worst_trade,
                AVG(price_at_trade)                             AS avg_price
            FROM trades
            WHERE strategy IS NOT NULL
            GROUP BY strategy
            ORDER BY total_pnl DESC
        
