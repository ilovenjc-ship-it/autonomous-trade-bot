APP_NAME=TAO Trading Bot
DEBUG=true
HOST=0.0.0.0
PORT=8001

DATABASE_URL=sqlite+aiosqlite:///./trading_bot.db
DATABASE_SYNC_URL=sqlite:///./trading_bot.db

FRONTEND_URL=http://localhost:3002

BT_NETWORK=finney
BT_NETUID=1
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets

DEFAULT_TRADE_AMOUNT=0.1
MAX_TRADE_AMOUNT=10.0
MIN_TRADE_AMOUNT=0.001
TRADE_INTERVAL_SECONDS=300
MAX_DAILY_TRADES=50
STOP_LOSS_PCT=5.0
TAKE_PROFIT_PCT=10.0